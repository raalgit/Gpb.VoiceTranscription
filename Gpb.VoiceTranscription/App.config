<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- Базовый URL по умолчанию (HuggingFace) -->
		<add key="WhisperBaseUrl" value="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/" />

		<!-- Раскомментируйте и измените эту строку, чтобы использовать локальный репозиторий -->
		<!-- <add key="WhisperBaseUrl" value="http://localhost:8080/models/" /> -->

		<!-- Таймаут скачивания в минутах -->
		<add key="DownloadTimeoutMinutes" value="10" />
	</appSettings>
</configuration>