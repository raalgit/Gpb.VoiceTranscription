<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- Базовый URL по умолчанию (HuggingFace) -->
		<add key="WhisperBaseUrl" value="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/" />

		<!-- Раскомментируйте и измените эту строку, чтобы использовать локальный репозиторий -->
		<!-- <add key="WhisperBaseUrl" value="http://localhost:8080/models/" /> -->

		<!-- Таймаут скачивания в минутах -->
		<add key="DownloadTimeoutMinutes" value="10" />
		
		<!-- Настройки суммаризации -->
		<!-- API ключ для сервиса суммаризации (например, OpenAI) -->
		<add key="SummarizationApiKey" value="PAST_API_KEY" />
		<!-- URL endpoint для суммаризации (OpenAI compatible API) -->
		<add key="SummarizationEndpoint" value="https://openai.api.proxyapi.ru/v1/chat/completions" />
		<!-- Модель для суммаризации -->
		<add key="SummarizationModel" value="anthropic/claude-sonnet-4-20250514" />
		<!-- Максимальная длина текста для суммаризации (символов). Если текст длиннее, будет обрезан -->
		<add key="SummarizationMaxTextLength" value="15000" />
		<!-- Включить суммаризацию по умолчанию -->
		<add key="EnableSummarization" value="true" />
	</appSettings>
</configuration>