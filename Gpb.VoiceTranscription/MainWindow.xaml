<Window x:Class="Gpb.VoiceTranscription.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Gpb.VoiceTranscription.ViewModels" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        Title="🎙️ Audio to Text (Whisper)" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="#ffffff" 
        MinWidth="800"
        MinHeight="600">
    <Window.Resources>
        <!-- Стили кнопок -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078d4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005a9e"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3e3e42"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Выбор файла -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Чекбокс -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Прогресс и статус -->
            <RowDefinition Height="*"/>
            <!-- 4: Результат (растягивается) -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🎙️ Транскрибация аудио" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="Whisper.net • WAV → Text" 
                       FontSize="14" Foreground="#888888"/>
        </StackPanel>

        <!-- Область выбора файла и записи -->
        <Border Grid.Row="1" BorderBrush="#3e3e42" BorderThickness="1" 
                CornerRadius="8" Padding="15" Margin="0,0,0,15"
                Background="#252526">
            <StackPanel>
                <TextBlock Text="📁 Выберите WAV-файл или запишите новый" FontWeight="SemiBold" Foreground="#d4d4d4" Margin="0,0,0,10"/>

                <!-- Выбор файла -->
                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                    <Button Content="🔍 Обзор..." Command="{Binding SelectFileCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            DockPanel.Dock="Right" Width="100"/>
                    <TextBox Text="{Binding SelectedFilePath, Mode=OneWay}" 
                             IsReadOnly="True" Background="#333337" Foreground="#d4d4d4" BorderThickness="0"
                             Padding="10,8" VerticalContentAlignment="Center"/>
                </DockPanel>

                <!-- Drag & Drop зона -->
                <Border BorderBrush="#0078d4" BorderThickness="1" 
                        CornerRadius="4" Padding="20" Background="#2d2d30"
                        AllowDrop="True" DragOver="Border_DragOver" Drop="Border_Drop"
                        Margin="0,0,0,15">
                    <TextBlock Text="📥 Перетащите WAV-файл сюда" 
                               Foreground="#888888" TextAlignment="Center"/>
                </Border>

                <!-- Секция записи аудио -->
                <Border BorderBrush="#0078d4" BorderThickness="1" 
                        CornerRadius="4" Padding="15" Background="#2d2d30">
                    <StackPanel>
                        <TextBlock Text="🎙️ Запись аудио" FontWeight="SemiBold" Foreground="#d4d4d4" Margin="0,0,0,10"/>
                        
                        <!-- Выбор устройства -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Источник звука:" Foreground="#888888" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding AvailableDevices}" 
                                      SelectedValuePath="index"
                                      SelectedValue="{Binding SelectedDeviceIndex}"
                                      DisplayMemberPath="name"
                                      Background="#333337" Foreground="#d4d4d4"
                                      Padding="8,5"
                                      SelectionChanged="ComboBox_SelectionChanged"/>
                            <TextBlock Text="💡 Для записи голоса других людей из наушников выберите устройство с префиксом 🔊 Loopback" 
                                       Foreground="#888888" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Кнопки записи -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="⏺️ Запись" 
                                    Command="{Binding StartRecordingCommand}"
                                    Style="{StaticResource PrimaryButton}" 
                                    Background="#d43e3e"
                                    Margin="0,0,10,0"
                                    IsEnabled="{Binding IsRecording, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            <Button Content="⏹️ Стоп" 
                                    Command="{Binding StopRecordingCommand}"
                                    Style="{StaticResource PrimaryButton}" 
                                    Background="#3e8e3e"
                                    IsEnabled="{Binding IsRecording}"/>
                        </StackPanel>

                        <!-- Индикатор записи -->
                        <TextBlock Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"
                                   Text="🔴 Идёт запись..." 
                                   Foreground="#d43e3e" 
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <CheckBox Content="⚙️ Автоматически конвертировать аудио в 16kHz Mono WAV" 
  IsChecked="{Binding AutoConvertAudio}" 
          Foreground="#d4d4d4"
  Grid.Row="2" Margin="0,5"
  ToolTip="Если файл не соответствует требованиям Whisper, он будет сконвертирован автоматически" Cursor=""/>

        <!-- Прогресс и статус -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <!-- Пример привязки -->
            <ProgressBar 
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" 
                Value="{Binding ProgressValue}" 
                Height="8"/>

            <TextBlock 
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" 
                Text="🟡 Готов к работе"/>
        </StackPanel>

        <!-- Результат -->
        <Grid Grid.Row="4" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" Grid.RowSpan="3" x:Name="ResultGrid">
            <Border Background="#252526" CornerRadius="8" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding TranscriptionResult, Mode=OneWay}"
                             Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" Foreground="#d4d4d4"
                             IsReadOnly="True" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="▶️ Начать" Command="{Binding StartTranscriptionCommand}"
            Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="⏹️ Отмена" Command="{Binding CancelCommand}"
            Background="#6e3e6e" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="💾 Сохранить .md" Command="{Binding SaveResultCommand}"
            Background="#2d7d2d" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
