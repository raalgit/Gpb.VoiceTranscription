<Window x:Class="Gpb.VoiceTranscription.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Gpb.VoiceTranscription.ViewModels" 
        xmlns:converters="clr-namespace:Gpb.VoiceTranscription.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        Title="🎙️ Audio to Text (Whisper)" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="#ffffff" 
        MinWidth="800"
        MinHeight="600">
    <Window.Resources>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" 
                        Grid.ColumnSpan="2"
                        CornerRadius="0"
                        Background="#FF3F3F3F"
                        BorderBrush="#FF97A0A5"
                        BorderThickness="1" />
                <Border Grid.Column="0"
                        CornerRadius="0" 
                        Margin="1" 
                        Background="#FF3F3F3F" 
                        BorderBrush="#FF97A0A5"
                        BorderThickness="0,0,1,0" />
                <Path x:Name="Arrow"
                      Grid.Column="1"     
                      Fill="White"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z"
                    />
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="{x:Type TextBox}">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
        </ControlTemplate>

        <Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton 
                                Name="ToggleButton" 
                                Template="{StaticResource ComboBoxToggleButton}" 
                                Grid.Column="2" 
                                Focusable="false"
                                IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press">
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="3,3,23,3"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox"
                                Style="{x:Null}" 
                                Template="{StaticResource ComboBoxTextBox}" 
                                HorizontalAlignment="Left" 
                                VerticalAlignment="Center" 
                                Margin="3,3,23,3"
                                Focusable="True" 
                                Background="#FF3F3F3F"
                                Foreground="Green"
                                Visibility="Hidden"
                                IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup 
                                Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True" 
                                Focusable="False"
                                PopupAnimation="Slide">

                                <Grid Name="DropDown"
                                  SnapsToDevicePixels="True"                
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border 
                                    x:Name="DropDownBorder"
                                    Background="#FF3F3F3F"
                                     
                                    BorderThickness="1"
                                    BorderBrush="#888888"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                            <Trigger SourceName="Popup" Property="Popup.AllowsTransparency" Value="true">
                                <Setter TargetName="DropDownBorder" Property="CornerRadius" Value="0"/>
                                <Setter TargetName="DropDownBorder" Property="Margin" Value="0,2,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEditable"  Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
            </Style.Triggers>
        </Style>

        <!-- SimpleStyles: ComboBoxItem -->
        <Style x:Key="{x:Type ComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border Name="Border"
                                  Padding="2"
                                  SnapsToDevicePixels="true">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#FF4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Стили кнопок -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078d4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005a9e"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3e3e42"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NegationConverter x:Key="InvertedConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Выбор файла -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Чекбокс -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Прогресс и статус -->
            <RowDefinition Height="*"/>
            <!-- 4: Результат (растягивается) -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🎙️ Транскрибация аудио" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="Whisper.net • WAV/MP3/MP4 → Text" 
                       FontSize="14" Foreground="#888888"/>
        </StackPanel>

        <!-- Область выбора файла и записи -->
        <Border Grid.Row="1" BorderBrush="#3e3e42" BorderThickness="1" 
                CornerRadius="8" Padding="15" Margin="0,0,0,15"
                Background="#252526">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Grid.Column="0">
                    <TextBlock Text="📁 Выберите аудиофайл (WAV, MP3, MP4) или запишите новый" FontWeight="SemiBold" Foreground="#d4d4d4" Margin="0,0,0,10"/>

                    <!-- Выбор файла -->
                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                        <Button Content="🔍 Обзор..." Command="{Binding SelectFileCommand}" Style="{StaticResource PrimaryButton}" DockPanel.Dock="Right" Width="100"/>
                        <TextBox Text="{Binding SelectedFilePath, Mode=OneWay}" IsReadOnly="True" Background="#333337" Foreground="#d4d4d4" BorderThickness="0" Padding="10,8" VerticalContentAlignment="Center"/>
                    </DockPanel>

                    <!-- Drag & Drop зона -->
                    <Border BorderBrush="#0078d4" BorderThickness="1" 
                            CornerRadius="4" Padding="20" Background="#2d2d30"
                            AllowDrop="True" DragOver="Border_DragOver" Drop="Border_Drop"
                            Margin="0,0,0,15">
                        <TextBlock Text="📥 Перетащите аудиофайл (WAV, MP3, MP4) сюда" Foreground="#888888" TextAlignment="Center"/>
                    </Border>

                    <TextBlock Text="🤖 Выбор модели Whisper" FontWeight="SemiBold" Foreground="#d4d4d4" Margin="0,0,0,10"/>

                    <!-- Выбор модели -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Модель:" Foreground="#888888" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableModels}" 
                                      SelectedItem="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}"
                                      Background="#333337" Foreground="#d4d4d4"
                                      Padding="8,5"
                                      IsEnabled="{Binding IsDownloadingModel, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock Text=" (скачать)"
                                                       Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                                       Foreground="#888888" FontStyle="Italic"
                                                       Opacity="0.5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="💡 Скачанные модели доступны для транскрибации. При выборе нескачанной модели начнётся загрузка." 
                                       Foreground="#888888" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>

                        <!-- Индикатор скачивания -->
                        <ProgressBar Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVis}}"
                                      Value="{Binding DownloadProgress}"
                                      Height="8" Margin="0,10,0,0"/>
                        <TextBlock Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVis}}"
                                       Text="{Binding StatusMessage}" 
                                       Foreground="#3e8e3e" 
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Секция записи аудио -->
                <Border Grid.Column="1" BorderBrush="#0078d4" BorderThickness="1" CornerRadius="4" Margin="15" Padding="10" Background="#2d2d30">
                    <StackPanel>
                        <TextBlock Text="🎙️ Запись аудио" FontWeight="SemiBold" Foreground="#d4d4d4" Margin="0,0,0,10"/>
                        
                        <!-- Выбор устройства -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Источник звука:" Foreground="#888888" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding AvailableDevices}" 
                                      SelectedValuePath="Index"
                                      SelectedValue="{Binding SelectedDeviceIndex}"
                                      DisplayMemberPath="Name"
                                      Background="#333337" Foreground="#d4d4d4"
                                      Padding="8,5"
                                      SelectionChanged="ComboBox_SelectionChanged"/>
                            <TextBlock Text="💡 Для записи голоса других людей из наушников выберите устройство с префиксом 🔊 Loopback" 
                                       Foreground="#888888" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Кнопки записи -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="⏺️ Запись" 
                                    Command="{Binding StartRecordingCommand}"
                                    Style="{StaticResource PrimaryButton}" 
                                    Background="#d43e3e"
                                    Margin="0,0,10,0"
                                    IsEnabled="{Binding IsRecording, Converter={StaticResource InvertedConverter}}"/>
                            <Button Content="⏹️ Стоп" 
                                    Command="{Binding StopRecordingCommand}"
                                    Style="{StaticResource PrimaryButton}" 
                                    Background="#3e8e3e"
                                    IsEnabled="{Binding IsRecording}"/>
                        </StackPanel>

                        <!-- Индикатор записи -->
                        <TextBlock Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"
                                   Text="🔴 Идёт запись..." 
                                   Foreground="#d43e3e" 
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <CheckBox Content="⚙️ Автоматически конвертировать аудио в 16kHz Mono WAV" 
  IsChecked="{Binding AutoConvertAudio}" 
          Foreground="#d4d4d4"
  Grid.Row="2" Margin="0,5"
  ToolTip="Если файл не соответствует требованиям Whisper, он будет сконвертирован автоматически" Cursor=""/>

        <CheckBox Content="⚡ Обрабатывать большие файлы по чанкам (рекомендуется для файлов >10 мин)"
                  IsChecked="{Binding UseChunkingForLargeFiles}"
                  Foreground="#d4d4d4"
                  Grid.Row="2" Margin="0,30,0,5"
                  ToolTip="Разбивает файлы длительностью более 10 минут на части для стабильной обработки"/>

        <CheckBox Content="📝 Суммаризировать текст после транскрибации (требуется API ключ)"
                  IsChecked="{Binding EnableSummarization}"
                  Foreground="#d4d4d4"
                  Grid.Row="2" Margin="0,55,0,5"
                  ToolTip="Создаёт краткое резюме совещания с помощью AI. Требуется настроить SummarizationApiKey в конфиге."/>

        <!-- Прогресс и статус -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <!-- Пример привязки -->
            <ProgressBar 
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" 
                Value="{Binding ProgressValue}" 
                Height="8"/>

            <TextBlock Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
               Text="{Binding StatusMessage}" 
               Foreground="#888888" 
               FontWeight="Bold"
               TextAlignment="Center"
               Margin="0,5,0,0"/>
               
            <!-- Индикатор суммаризации -->
            <TextBlock Visibility="{Binding IsSummarizing, Converter={StaticResource BoolToVis}}"
               Text="📝 Выполняется суммаризация..." 
               Foreground="#FFA500" 
               FontWeight="Bold"
               TextAlignment="Center"
               Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Результат -->
        <Grid Grid.Row="4" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" Grid.RowSpan="3" x:Name="ResultGrid">
            <Border Background="#252526" CornerRadius="8" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding TranscriptionResult, Mode=OneWay}"
                             Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" Foreground="#d4d4d4"
                             IsReadOnly="True" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="▶️ Начать" Command="{Binding StartTranscriptionCommand}"
            Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="⏹️ Отмена" Command="{Binding CancelTranscriptionCommand}"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" 
            Background="#6e3e6e" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="💾 Сохранить .md" Command="{Binding SaveResultCommand}"
            Background="#2d7d2d" Style="{StaticResource PrimaryButton}" IsEnabled="{Binding HasResult}"/>
        </StackPanel>
    </Grid>
</Window>
